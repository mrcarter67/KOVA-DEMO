# ═══════════════════════════════════════════════════════
# KOVA Environment Configuration
# ═══════════════════════════════════════════════════════

# ── AI Provider ─────────────────────────────────────────
# "claude"  → Use Anthropic Claude API (cloud, development)
# "ollama"  → Use local Llama 4 via Ollama (private, production)
AI_PROVIDER=claude

# Claude API (required when AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (required when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://kova:password@localhost:5432/kova
POSTGRES_PASSWORD=your-secure-password

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret

# ── Email ────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxx

# ── Storage ─────────────────────────────────────────────
CLOUDFLARE_R2_BUCKET=kova-documents
CLOUDFLARE_R2_ACCOUNT_ID=xxx
CLOUDFLARE_R2_ACCESS_KEY=xxx
CLOUDFLARE_R2_SECRET_KEY=xxx
